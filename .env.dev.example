# ╔══════════════════════════════════════════════════════════╗
# ║  ProfitableWeb — DEV (docker-compose.dev.yml)            ║
# ║  На сервере: .env.dev  |  В CI/CD: GitHub Secrets        ║
# ╚══════════════════════════════════════════════════════════╝

# ── PostgreSQL ────────────────────────────────────
POSTGRES_DB=profitableweb_dev
POSTGRES_USER=pw
POSTGRES_PASSWORD=<сгенерировать надёжный пароль>

# ── FastAPI ───────────────────────────────────────
# DATABASE_URL формируется в docker-compose из POSTGRES_*
JWT_SECRET=<сгенерировать надёжный секрет>
FRONTEND_URL=https://dev.profitableweb.ru
ADMIN_URL=https://dev.profitableweb.ru/admin
CORS_ORIGINS=["https://dev.profitableweb.ru"]

# ── OAuth-провайдеры ──────────────────────────────
# Можно использовать те же, что и для prod, или отдельные
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# ── Cloud.ru Object Storage (S3) ─────────────────
STORAGE_BACKEND=s3
S3_ENDPOINT=https://s3.cloud.ru
S3_BUCKET=pw-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central-1
S3_PUBLIC_ENDPOINT=https://global.s3.cloud.ru
