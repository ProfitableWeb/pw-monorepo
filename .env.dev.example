# === Postgres ===
POSTGRES_DB=profitableweb_dev
POSTGRES_USER=pw
POSTGRES_PASSWORD=devpassword

# === API (FastAPI) ===
# DATABASE_URL переопределяется в docker-compose через environment
JWT_SECRET=dev-secret
FRONTEND_URL=http://dev.profitableweb.ru
ADMIN_URL=http://dev.profitableweb.ru/admin
CORS_ORIGINS=["http://dev.profitableweb.ru"]

# OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# S3 Storage
STORAGE_BACKEND=s3
S3_ENDPOINT=
S3_BUCKET=pw-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-1
S3_PUBLIC_ENDPOINT=
