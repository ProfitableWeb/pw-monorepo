{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["turbo", "dev", "--filter=@profitable-web/web"],
      "port": 3000
    },
    {
      "name": "admin",
      "runtimeExecutable": "bun",
      "runtimeArgs": ["turbo", "dev", "--filter=@profitable-web/admin"],
      "port": 3001
    },
    {
      "name": "api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "--directory", "apps/api", "uvicorn", "src.main:app", "--reload", "--port", "8000"],
      "port": 8000
    }
  ]
}
