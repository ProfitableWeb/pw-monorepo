# ╔══════════════════════════════════════════════════════════╗
# ║  ProfitableWeb — PROD (docker-compose.prod.yml)          ║
# ║  На сервере: .env.prod  |  В CI/CD: GitHub Secrets       ║
# ╚══════════════════════════════════════════════════════════╝

# ── PostgreSQL ────────────────────────────────────
POSTGRES_DB=profitableweb
POSTGRES_USER=pw
POSTGRES_PASSWORD=<сгенерировать надёжный пароль>

# ── FastAPI ───────────────────────────────────────
# DATABASE_URL формируется в docker-compose из POSTGRES_*
JWT_SECRET=<сгенерировать надёжный секрет>
FRONTEND_URL=https://profitableweb.ru
ADMIN_URL=https://profitableweb.ru/admin
CORS_ORIGINS=["https://profitableweb.ru"]

# ── OAuth-провайдеры ──────────────────────────────
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# ── Cloud.ru Object Storage (S3) ─────────────────
STORAGE_BACKEND=s3
S3_ENDPOINT=https://s3.cloud.ru
S3_BUCKET=pw-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central-1
S3_PUBLIC_ENDPOINT=https://global.s3.cloud.ru
