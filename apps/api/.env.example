# ╔══════════════════════════════════════════════════════════╗
# ║  ProfitableWeb — шаблон переменных окружения             ║
# ║  Зеркало GitHub Secrets: все переменные перечислены       ║
# ║  Скопируйте в .env и заполните значения                  ║
# ╚══════════════════════════════════════════════════════════╝

# ── SSH-доступ к серверу ──────────────────────────
# CI/CD: подключение к VM для деплоя
SSH_PRIVATE_KEY=
SSH_USER=
SSH_PASSWORD=
SSH_HOST=
SSH_PORT=22

# ── PostgreSQL (prod) ────────────────────────────
# CI/CD: docker-compose.prod.yml
POSTGRES_DB=profitableweb
POSTGRES_USER=pw
POSTGRES_PASSWORD=

# ── PostgreSQL + JWT (dev) ────────────────────────
# CI/CD: docker-compose.dev.yml
DEV_POSTGRES_PASSWORD=
DEV_JWT_SECRET=

# ── FastAPI: приложение ──────────────────────────
DEBUG=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/profitableweb
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── FastAPI: JWT ─────────────────────────────────
JWT_SECRET=change-me-in-production

# ── FastAPI: OAuth-провайдеры ────────────────────

# Yandex ID (https://oauth.yandex.ru)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Google OAuth 2.0 (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram Login Widget (@BotFather)
TELEGRAM_BOT_TOKEN=

# ── FastAPI: Frontend URLs ───────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── FastAPI: Cloud.ru Object Storage (S3) ────────
# Документация: docs/architecture/runbooks/cloud-ru-s3-setup.md
STORAGE_BACKEND=local
S3_ENDPOINT=https://s3.cloud.ru
S3_BUCKET=pw-media
# Формат access key для Cloud.ru: <tenant_id>:<key_id>
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central-1
S3_PUBLIC_ENDPOINT=https://global.s3.cloud.ru
