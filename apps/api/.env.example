APP_NAME=ProfitableWeb API
DEBUG=true

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

DATABASE_URL=

# ── OAuth Providers ──────────────────────────────────
 
# Yandex ID
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
 
# Telegram Login Widget
TELEGRAM_BOT_TOKEN=
 
# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Cloud.ru Object Storage (S3) ──────────────
# Документация: docs/architecture/runbooks/cloud-ru-s3-setup.md
STORAGE_BACKEND=s3  # "local" (диск VM + nginx) или "s3" (Cloud.ru)

# API endpoint (для boto3 — put/get/delete)
S3_ENDPOINT=https://s3.cloud.ru
# Публичный endpoint (для URL изображений в браузере)
# Cloud.ru basic endpoint НЕ поддерживает анонимный доступ — нужен global
S3_PUBLIC_ENDPOINT=https://global.s3.cloud.ru
S3_BUCKET=pw-media
# ВАЖНО: формат access key для Cloud.ru — <tenant_id>:<key_id>
# tenant_id — UUID из панели Object Storage API (~36 символов)
# key_id — сам ключ (~32 символа), итого ~69 символов через двоеточие
# Без tenant_id Cloud.ru вернёт InvalidAccessKeyId
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ru-central-1